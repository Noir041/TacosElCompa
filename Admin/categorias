<?php
session_start();
if(!isset($_SESSION['admin_id'])) {
    header('Location: login.php');
    exit;
}
require_once '../includes/db.php';

$mensaje = '';
$error = '';

// AGREGAR CATEGORÍA
if($_SERVER['REQUEST_METHOD'] == 'POST' && isset($_POST['agregar'])) {
    $nombre = trim($_POST['nombre']);
    $orden = intval($_POST['orden']);
    
    if(empty($nombre)) {
        $error = 'El nombre de la categoría es obligatorio';
    } else {
        $stmt = $pdo->prepare("SELECT id FROM categorias WHERE nombre = ?");
        $stmt->execute([$nombre]);
        if($stmt->fetch()) {
            $error = 'Ya existe una categoría con ese nombre';
        } else {
            $stmt = $pdo->prepare("INSERT INTO categorias (nombre, orden) VALUES (?, ?)");
            $stmt->execute([$nombre, $orden]);
            $mensaje = '✅ Categoría "' . htmlspecialchars($nombre) . '" agregada correctamente';
        }
    }
}

// EDITAR CATEGORÍA
if($_SERVER['REQUEST_METHOD'] == 'POST' && isset($_POST['editar'])) {
    $id = intval($_POST['id']);
    $nombre = trim($_POST['nombre']);
    $orden = intval($_POST['orden']);
    
    if(empty($nombre)) {
        $error = 'El nombre de la categoría es obligatorio';
    } else {
        $stmt = $pdo->prepare("SELECT id FROM categorias WHERE nombre = ? AND id != ?");
        $stmt->execute([$nombre, $id]);
        if($stmt->fetch()) {
            $error = 'Ya existe otra categoría con ese nombre';
        } else {
            $stmt = $pdo->prepare("UPDATE categorias SET nombre = ?, orden = ? WHERE id = ?");
            $stmt->execute([$nombre, $orden, $id]);
            $mensaje = '✅ Categoría actualizada correctamente';
        }
    }
}

// ELIMINAR CATEGORÍA
if(isset($_GET['eliminar'])) {
    $id = intval($_GET['eliminar']);
    
    $stmt = $pdo->prepare("SELECT COUNT(*) FROM platillos WHERE categoria_id = ?");
    $stmt->execute([$id]);
    $total = $stmt->fetchColumn();
    
    if($total > 0) {
        $error = "❌ No se puede eliminar: hay $total platillo(s) en esta categoría. Reasígnelos primero.";
    } else {
        $stmt = $pdo->prepare("DELETE FROM categorias WHERE id = ?");
        $stmt->execute([$id]);
        $mensaje = '✅ Categoría eliminada correctamente';
    }
}

// PAGINACIÓN
$por_pagina = 5;
$total_categorias = $pdo->query("SELECT COUNT(*) FROM categorias")->fetchColumn();
$total_paginas = ceil($total_categorias / $por_pagina);
$pagina_actual = isset($_GET['pagina']) ? max(1, intval($_GET['pagina'])) : 1;
$offset = ($pagina_actual - 1) * $por_pagina;

// Obtener categorías con límite
$stmt = $pdo->prepare("
    SELECT c.*, COUNT(p.id) as total_platillos 
    FROM categorias c 
    LEFT JOIN platillos p ON c.id = p.categoria_id 
    GROUP BY c.id 
    ORDER BY c.orden ASC 
    LIMIT ? OFFSET ?
");
$stmt->execute([$por_pagina, $offset]);
$categorias = $stmt->fetchAll();

$maxOrden = $pdo->query("SELECT MAX(orden) FROM categorias")->fetchColumn();
$siguienteOrden = $maxOrden ? $maxOrden + 1 : 1;
$totalPlatillosTodos = $pdo->query("SELECT COUNT(*) FROM platillos")->fetchColumn();
?>
